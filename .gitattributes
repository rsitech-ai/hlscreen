# Preserve third-party license text exactly as packaged upstream. Some selected
# licenses intentionally contain CRLF or trailing spaces, so Git's whitespace
# checker must not rewrite or reject this generated legal artifact.
THIRD_PARTY_LICENSES.txt -text whitespace=-trailing-space,-cr-at-eol

# Keep maintainer journals and repository automation out of cargo-dist's source
# archive. They remain reviewable in Git history and the public repository.
/.agents export-ignore
/.specify export-ignore
/memory export-ignore
/plans export-ignore
/reflections export-ignore
/PLAN.md export-ignore
/MEMORY.md export-ignore
/TODO.md export-ignore
